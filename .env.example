# Copy this file to .env and add your actual API key
# Get your free API key from: https://console.groq.com/

# Required: Your Groq API key
GROQ_API_KEY=your-groq-api-key-here

# Optional: LLM Configuration (defaults shown)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# Optional: Memory Configuration (defaults shown)
SHORT_TERM_MEMORY_LIMIT=5
LONG_TERM_MEMORY_LIMIT=50

# Optional: Emotion Configuration (defaults shown)
EMOTION_DECAY_RATE=0.1

# Optional: Game Configuration (defaults shown)
MAX_TURN_LENGTH=500
